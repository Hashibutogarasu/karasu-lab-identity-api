rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(authorId) {
      return isAuthenticated() && request.auth.uid == authorId;
    }

    function isPublished(res) {
      return res != null && res.data != null && res.data.status == 'published';
    }

    function isBlogOwner(res) {
      return res != null && res.data != null && isOwner(res.data.authorId);
    }

    match /blogs/{blogId} {
      allow read: if isPublished(resource) || isBlogOwner(resource);
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isBlogOwner(resource) && !resource.data.locked;

      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
      }
    }

    match /attachments/{attachmentId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.authorId) || get(/databases/$(database)/documents/blogs/$(resource.data.blogId)).data.status == 'published');
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.authorId);
    }
  }
}
